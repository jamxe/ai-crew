#!/usr/bin/env bash
# ai-continue — resume the latest AI session for a project
# Usage: ai-continue [--tool codewhale|opencode] [project-name]
#        ai-continue --list

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PYTHON="python3"
[ -f "$SCRIPT_DIR/../.venv/bin/python3" ] && PYTHON="$SCRIPT_DIR/../.venv/bin/python3"
OPENCODE="${OPENCODE:-$HOME/.opencode/bin/opencode}"
TOOL="codewhale"
PROJECT=""
LIST_MODE=0

usage() {
    cat <<'EOF'
Usage:
  ai-continue [--tool codewhale|opencode] [project-name]
  ai-continue --list

Options:
  --tool, -t  Backend: codewhale (default) or opencode
  --list, -l  List available sessions
  -h, --help  Show this help

Examples:
  ai-continue                    resume latest session in current dir
  ai-continue myproject          fuzzy-match project name
  ai-continue --tool opencode    resume latest OpenCode session
  ai-continue --list             list all sessions
EOF
}

while [ $# -gt 0 ]; do
    case "$1" in
        -t|--tool) shift; TOOL="$1"; shift ;;
        -l|--list) LIST_MODE=1; shift ;;
        -h|--help) usage; exit 0 ;;
        *) PROJECT="$1"; shift ;;
    esac
done

# ── Detect backend from .ai-crew.json if present ─────────────────────────────
CWD=$(pwd)
for d in "$CWD" "$(dirname "$CWD")" "$(dirname "$(dirname "$CWD")")"; do
    if [ -f "$d/.ai-crew.json" ]; then
        DETECTED=$(python3 -c "import json;c=json.load(open('$d/.ai-crew.json'));print(c.get('supervisor',c.get('worker','codewhale')))" 2>/dev/null || echo "codewhale")
        TOOL="$DETECTED"
        break
    fi
done

# ═══════════════════════════════════════════════════════════════════════════════
# CodeWhale backend
# ═══════════════════════════════════════════════════════════════════════════════
if [ "$TOOL" = "codewhale" ]; then
    if [ "$LIST_MODE" -eq 1 ]; then
        codewhale sessions 2>&1
        exit 0
    fi

    if [ -n "$PROJECT" ]; then
        echo "🔍 Matching '$PROJECT' against CodeWhale sessions..." >&2
        # Use standalone matcher (avoids inline-Python quoting hell)
        sid=$(codewhale sessions 2>/dev/null | "$PYTHON" "$SCRIPT_DIR/ai-match.py" "$PROJECT" 2>/dev/null)

        if [ -n "$sid" ]; then
            echo "🔄 Resuming session ${sid:0:8}..." >&2
            exec codewhale exec --resume "$sid" --auto
        else
            echo "❌ No match for '$PROJECT'" >&2
            echo "   Try: ai-continue --list" >&2
            exit 1
        fi
    else
        echo "🔄 Resuming latest session..." >&2
        exec codewhale exec --continue --auto
    fi

# ═══════════════════════════════════════════════════════════════════════════════
# OpenCode backend
# ═══════════════════════════════════════════════════════════════════════════════
elif [ "$TOOL" = "opencode" ]; then
    if [ "$LIST_MODE" -eq 1 ]; then
        echo "═══ OpenCode Sessions ═══"
        "$OPENCODE" session list 2>&1 || echo "  (unavailable)"
        exit $?
    fi

    if [ -n "$PROJECT" ]; then
        echo "🔍 Matching '$PROJECT' against OpenCode sessions..." >&2
        # OpenCode sessions: use `opencode session list` and fuzzy-match
        sid=$("$OPENCODE" session list 2>/dev/null | "$PYTHON" -c "
import json, sys
q = '$PROJECT'.lower()
best_score, best_id = 0, ''
for line in sys.stdin:
    line = line.strip()
    if not line: continue
    # OpenCode output format varies; try JSON first
    try:
        s = json.loads(line)
        ws = (s.get('workspace','') or s.get('cwd','') or '').lower()
        title = (s.get('title','') or '').lower()
        sid = s.get('id','') or s.get('sessionId','')
    except:
        # Plain text format
        lower = line.lower()
        if q in lower:
            sid = line.split()[0] if line.split() else ''
            ws = lower
            title = ''
        else:
            continue
    score = 0
    if q in ws: score += 100
    if q in title: score += 50
    if score > best_score:
        best_score = score
        best_id = sid
if best_id:
    print(best_id)
" 2>/dev/null)

        if [ -n "$sid" ]; then
            echo "🔄 Resuming OpenCode session ${sid:0:8}..." >&2
            exec "$OPENCODE" run --session "$sid" --dangerously-skip-permissions
        else
            echo "❌ No OpenCode match for '$PROJECT', trying --continue..." >&2
            exec "$OPENCODE" run --continue
        fi
    else
        echo "🔄 Resuming latest OpenCode session..." >&2
        exec "$OPENCODE" run --continue
    fi

else
    echo "ai-continue: unknown tool '$TOOL'. Use codewhale or opencode." >&2
    exit 1
fi
